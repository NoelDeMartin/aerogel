{
    "private": true,
    "type": "module",
    "repository": "github:NoelDeMartin/aerogel",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "dev:serve-pod": "community-solid-server -c @css:config/file.json -f ./solid",
        "e2e:dev": "concurrently --kill-others \"pnpm e2e:serve-app\" \"pnpm e2e:serve-pod\" \"pnpm e2e:open\"",
        "e2e:open": "playwright test --ui",
        "e2e:run": "playwright test",
        "e2e:serve-app": "vite --port 5001 --mode testing",
        "e2e:serve-pod": "community-solid-server -l warn",
        "e2e:test": "start-server-and-test e2e:serve-app http-get://localhost:5001 e2e:serve-pod http-get://localhost:3000 e2e:run",
        "lint": "noeldemartin-lint src e2e"
    },
    "dependencies": {
        "@aerogel/core": "workspace:*",
        "@aerogel/plugin-i18n": "workspace:*",
        "@aerogel/plugin-local-first": "workspace:*",
        "@aerogel/plugin-routing": "workspace:*",
        "@aerogel/plugin-solid": "workspace:*",
        "@noeldemartin/solid-utils": "catalog:",
        "@noeldemartin/utils": "catalog:",
        "@tailwindcss/forms": "^0.5.10",
        "@tailwindcss/typography": "^0.5.16",
        "soukai-bis": "catalog:",
        "tailwindcss": "^4.1.4",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@aerogel/cli": "workspace:*",
        "@aerogel/playwright": "workspace:*",
        "@aerogel/vite": "workspace:*",
        "@noeldemartin/scripts": "catalog:",
        "@playwright/test": "^1.60.0",
        "@solid/community-server": "^7.1.3",
        "@types/node": "catalog:",
        "autoprefixer": "^10.4.14",
        "concurrently": "^8.0.1",
        "eslint": "catalog:",
        "eslint-plugin-vue": "catalog:",
        "publint": "catalog:",
        "start-server-and-test": "^2.0.0"
    },
    "eslintConfig": {
        "extends": [
            "@noeldemartin/eslint-config-vue"
        ]
    }
}
